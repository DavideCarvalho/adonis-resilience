{
  "name": "@agora/resilience-store-lucid",
  "version": "0.1.0",
  "description": "AdonisJS Lucid-backed circuit-breaker ResilienceStore for @agora/resilience. Part of the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-resilience.git",
    "directory": "packages/store-lucid"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
